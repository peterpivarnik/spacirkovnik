---
const today = new Date();
---

<footer>
	<div class="footer-social">
		<a href="https://www.facebook.com/profile.php?id=61590250423661" target="_blank" rel="noopener" aria-label="Facebook">
			<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
		</a>
		<a href="https://www.instagram.com/spacirkovnik" target="_blank" rel="noopener" aria-label="Instagram">
			<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
		</a>
	</div>
	<div class="footer-links">
		<a href="mailto:info@spacirkovnik.sk">info@spacirkovnik.sk</a>
		<span>·</span>
		<a href="/kontakt">Kontakt</a>
		<span>·</span>
		<a href="/obchodne-podmienky/">Obchodné podmienky</a>
		<span>·</span>
		<a href="/zasady-ochrany-osobnych-udajov/">Ochrana súkromia</a>
	</div>
	<div class="copyright">
		&copy; {today.getFullYear()} Špacírkovník. Všetky práva vyhradené.
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 3em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.75em;
		flex-wrap: wrap;
	}
	.footer-links a {
		text-decoration: none;
		color: rgb(var(--gray));
		font-size: 0.9em;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.footer-links span {
		color: rgb(var(--gray-light));
	}
	.footer-social {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.footer-social a {
		color: rgb(var(--gray));
		transition: color 0.2s;
	}
	.footer-social a:hover {
		color: var(--accent);
	}
	.copyright {
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
</style>
